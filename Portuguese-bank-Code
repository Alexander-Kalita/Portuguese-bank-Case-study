        for p in ax.patches:
            height = p.get_height()
            ax.text(p.get_x()+p.get_width()/2.,height+3,
            '{:.1f}%'.format(height/len(data)*100), ha="center")
    empty_ax = axes.flat[len(cat_cols):]
    for ax in empty_ax:
        ax.remove()
